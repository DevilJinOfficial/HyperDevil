{
  "name": "hyperdevil",
  "version": "1.0.1",
  "description": "HyperDevil - Windows Boot Configuration Manager for Game Modding",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "electron-store": "^8.1.0",
    "sudo-prompt": "^9.2.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.9.4",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.hyperdevil.app",
    "productName": "HyperDevil",
    "asarUnpack": [
      "assets/script/**",
      "assets/covers/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/HyperDevil.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "installerIcon": "assets/HyperDevil.ico",
      "uninstallDisplayName": "HyperDevil ${version}",
      "createDesktopShortcut": false,
      "runAfterFinish": true
    },
    "files": [
      "**/*",
      "!dist.rar",
      "!dist/**",
      "!installer/**",
      "!setup.iss",
      "!downloads/**",
      "!history/**",
      "!node_modules/**/*.map",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.md",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/doc/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/CHANGES*",
      "!node_modules/**/README*",
      "!node_modules/**/LICENSE*",
      "!node_modules/**/LICENCE*",
      "!node_modules/**/CONTRIBUTING*",
      "!node_modules/**/History*",
      "!node_modules/**/AUTHORS*"
    ]
  }
}
